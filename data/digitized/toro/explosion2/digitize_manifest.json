        1.0,
        0.5
      ],
      "image": "images/velocity.png",
      "output": "u_radial.csv",
      "columns": [
        "r",
        "u_radial"
      ],
      "axis_points": [
        {
          "data": [
            0.0,
            0.0
          ],
          "pixel": null
