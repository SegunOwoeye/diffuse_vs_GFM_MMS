{
  "source_image": "data/digitized/toro/explosion2/reference.png",
  "suite": "toro",
  "test": "explosion2",
  "layout": "four-panel",
  "notes": [
    "crop is [left, top, right, bottom]. Values <= 1 are treated as image fractions.",
    "axis_points map data values to crop image pixels as [row, column].",
    "Provide at least three axis_points: two on the x/r-axis and one on the y-axis."
  ],
  "fields": {
    "density": {
      "crop": [
        0.0,
        0.0,
        0.5,
        0.5
      ],
      "image": "images/density.png",
      "output": "rho.csv",
      "columns": [
        "r",
        "rho"
      ],
      "axis_points": [
        {
          "data": [
            0.0,
            0.0
          ],
          "pixel": null
        },
        {
          "data": [
            1.0,
            0.0
          ],
          "pixel": null
        },
        {
          "data": [
            0.0,
            1.0
          ],
          "pixel": null
        }
      ],
      "preprocess": false,
      "x_column": "r"
    },
    "pressure": {
      "crop": [
        0.0,
        0.5,
        0.5,
        1.0
      ],
      "image": "images/pressure.png",
      "output": "p.csv",
      "columns": [
        "r",
        "p"
      ],
      "axis_points": [
        {
          "data": [
            0.0,
            0.0
          ],
          "pixel": null
        },
        {
          "data": [
            1.0,
            0.0
          ],
          "pixel": null
        },
        {
          "data": [
            0.0,
            1.0
          ],
          "pixel": null
        }
      ],
      "preprocess": false,
      "x_column": "r"
    },
    "velocity": {
